# Greenside Environment Variables
# Copy this to .env and fill in your values

# Required - OpenAI API key for embeddings and chat
OPENAI_API_KEY=sk-your-openai-key-here

# Required - Pinecone for vector search
PINECONE_API_KEY=your-pinecone-key-here
PINECONE_INDEX=turf-research

# Optional - Web search fallback
TAVILY_API_KEY=your-tavily-key-here

# Optional - Weather integration
OPENWEATHER_API_KEY=your-openweather-key-here

# Flask configuration
FLASK_SECRET_KEY=generate-a-random-secret-key-here
APP_ENV=production
# Backward compatibility: FLASK_ENV is also accepted if APP_ENV is unset.
# FLASK_ENV=production
DEMO_MODE=false
ALLOW_PUBLIC_ADMIN=false
REQUIRE_EMAIL_VERIFICATION=false
